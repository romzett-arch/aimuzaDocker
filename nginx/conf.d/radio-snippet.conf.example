# Radio Engine — добавить в server {} перед location / {
# Прокси на 127.0.0.1 (radio контейнер пробросил порты на хост)

    # Icecast audio streams
    location /radio/stream.mp3 {
        proxy_pass http://127.0.0.1:8000/radio.mp3;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        tcp_nodelay on;
        gzip off;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-cache, no-store" always;
    }

    location /radio/stream.opus {
        proxy_pass http://127.0.0.1:8000/radio.opus;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        tcp_nodelay on;
        gzip off;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-cache, no-store" always;
    }

    location /radio/status {
        proxy_pass http://127.0.0.1:8000/status-json.xsl;
    }

    location /radio/api/ {
        proxy_pass http://127.0.0.1:3200/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }

    location /radio/ws {
        proxy_pass http://127.0.0.1:3200/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
