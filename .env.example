# ═══════════════════════════════════════════════
# AIMUZA — Environment Variables
# Скопируй в .env и заполни реальными значениями
# ═══════════════════════════════════════════════

# ── Database ──────────────────────────────────
DB_NAME=aimuza
DB_USER=aimuza
DB_PASSWORD=CHANGE_ME_strong_password

# ── API Server ────────────────────────────────
JWT_SECRET=CHANGE_ME_random_64_chars
SERVICE_ROLE_KEY=CHANGE_ME_service_key
ANON_KEY=placeholder_for_frontend
BASE_URL=http://localhost
CORS_ORIGIN=*

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost
# Совместимость с Supabase client:
VITE_SUPABASE_URL=http://localhost
VITE_SUPABASE_PUBLISHABLE_KEY=placeholder

# ── FFmpeg ────────────────────────────────────
# ОБЯЗАТЕЛЬНО для скачивания треков: без ключа треки скачиваются без нормализации и очистки метаданных.
# Deno получает FFMPEG_API_SECRET из FFMPEG_API_KEY (docker-compose).
FFMPEG_API_KEY=CHANGE_ME_ffmpeg_key

# ── Suno API (PiAPI) ─────────────────────────
SUNO_API_KEY=YOUR_PIAPI_KEY
#
# ⚠ КРИТИЧЕСКИ ВАЖНО: SUNO_CALLBACK_URL
#   VPS-деплой:  https://aimuza.ru/functions/v1/suno-callback  (ОБЯЗАТЕЛЬНО!)
#   Локалка:     http://localhost/functions/v1/suno-callback    (callback НЕ дойдёт, но polling работает)
#   ngrok:       https://xxxx.ngrok-free.app/functions/v1/suno-callback
#
# Если оставить localhost при деплое — треки навсегда застрянут в "processing"!
#
SUNO_CALLBACK_URL=https://aimuza.ru/functions/v1/suno-callback
# Секрет для верификации callback (опционально, но рекомендуется)
SUNO_CALLBACK_SECRET=CHANGE_ME_callback_secret

# ── AI (Qwen 3.5 Flash via Timeweb) ───────────
TIMEWEB_AGENT_ID=df42cd86-5e91-459e-a95a-a7befb625292
# ВНИМАНИЕ: Deno-функция suno-callback читает TIMEWEB_AGENT_TOKEN (не KEY)
TIMEWEB_AGENT_TOKEN=YOUR_KEY


# ── Payments ──────────────────────────────────
YOOKASSA_SHOP_ID=YOUR_SHOP_ID
YOOKASSA_SECRET_KEY=YOUR_SECRET
ROBOKASSA_MERCHANT_LOGIN=YOUR_LOGIN
ROBOKASSA_PASSWORD1=YOUR_PASS1
ROBOKASSA_PASSWORD2=YOUR_PASS2
ROBOKASSA_TEST_MODE=true

# ── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=noreply@aimuza.ru
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=AIMUZA <noreply@aimuza.ru>

# ── Radio (Icecast) ──────────────────────────
ICECAST_SOURCE_PASS=CHANGE_ME_STRONG_SOURCE_PASSWORD
ICECAST_ADMIN_PASS=CHANGE_ME_STRONG_ADMIN_PASSWORD
